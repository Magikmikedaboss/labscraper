[run]
branch = True

[report]
omit =
    run_rss_ingest.py
    tools/demo_output.py
    tools/demo_domains.py
    ui_control_panel.py
    utils/demo_domain_export.py
    utils/show_v4_exports.py
    utils/lint_seeds.py
    utils/overlay_scorer.py
    utils/verify_setup.py
    */test_*.py
show_missing = True
skip_covered = False
