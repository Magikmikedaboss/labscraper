{
  "id": "drug_discovery",
  "name": "Drug Discovery",
  "description": "Focuses on targets, compounds, assays, and escalation signals related to translational development. Observational patterns only.",
  "claims_mode": "observational_only",
  "domain_profile_version": "v1",
  "seed_overlays": {
    "include_files": [
      "targets.txt",
      "compounds.txt",
      "base/life_sciences/assays.txt",
      "pathways.json",
      "base/life_sciences/indications.json"
    ],
    "prefer_types": ["target", "compound", "assay", "pathway", "indication"]
  },
  "exclusions": {
    "terms": ["coupon", "buy now"],
    "doc_kinds": ["ecommerce", "marketing"]
  },
  "pattern_emphasis": {
    "convergence": 1.10,
    "escalation": 1.20,
    "fragmentation": 0.90,
    "stagnation": 1.00,
    "abandonment": 0.95
  },
  "language": {
    "allowed": ["en"],
    "output_allowed_phrases": ["research momentum", "validation effort", "appears to"],
    "forbidden": ["approved", "clinically proven"]
  }
}
