# Copy this file to .env if you want a local shell-friendly reference for common settings.

# Default database path used by scripts that accept a DB override.
DB_PATH=db/runs.sqlite

# Limit how many PDFs some scan utilities process.
LABSCRAPER_MAX_PDFS=50

# Optional scan tuning for the temporary single-lens utilities.
LABSCRAPER_MAX_PAGES_PER_PDF=5
LABSCRAPER_MAX_SENTENCES_PER_PAGE=200
MAX_WORKERS=4

# Extend construction-context matching without editing source code.
# LABSCRAPER_CONSTRUCTION_CONTEXT_TERMS_FILE is not auto-merged with LABSCRAPER_CONSTRUCTION_CONTEXT_TERMS.
LABSCRAPER_CONSTRUCTION_CONTEXT_TERMS="mechanical room,air handling unit,curtain wall"
LABSCRAPER_CONSTRUCTION_CONTEXT_TERMS_FILE="path/to/custom_construction_context_terms.txt"
